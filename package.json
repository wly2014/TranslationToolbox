{
	"name": "translationtoolbox",
	"displayName": "TranslationToolbox",
	"description": "划词翻译：有道短词 + 豆包长句；启动即激活",
	"keywords": ["translation", "youdao", "doubao", "LLM"],
	"version": "0.6.0",
	"publisher": "WLY",
	"icon": "images/icon.png",
	"engines": {
		"vscode": "^1.74.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./src/extension.js",
	"contributes": {
		"keybindings": [
			{
				"command": "translationtoolbox.translate",
				"key": "ctrl+alt+t",
				"mac": "cmd+alt+t",
				"when": "editorTextFocus"
			}
		],
		"commands": [
			{
				"command": "translationtoolbox.translate",
				"title": "translate"
			}
		],
		"configuration": {
			"title": "translationtoolbox",
			"properties": {
				"translationtoolbox.doubaoApiKey": {
					"type": "string",
					"default": "",
					"markdownDescription": "火山方舟 API Key（长句翻译必填）。若曾使用旧项 `DouBaoApiKey`，仍会自动读取。"
				},
				"translationtoolbox.doubaoModel": {
					"type": "string",
					"description": "豆包模型 ID（须与方舟已开通模型一致）",
					"enum": [
						"doubao-1.5-pro-32k-250115"
					],
					"default": "doubao-1.5-pro-32k-250115"
				},
				"translationtoolbox.DouBaoApiKey": {
					"type": "string",
					"default": "",
					"description": "（兼容旧版）豆包 API Key，优先使用 translationtoolbox.doubaoApiKey。"
				},
				"translationtoolbox.DouBaoModel": {
					"type": "string",
					"description": "（兼容旧版）模型 ID，优先使用 translationtoolbox.doubaoModel。",
					"enum": [
						"doubao-1.5-pro-32k-250115"
					],
					"default": "doubao-1.5-pro-32k-250115"
				}
			}
		}
	},
	"scripts": {
		"test": "node ./test/runTest.js",
		"lint": "eslint \"src/**/*.js\""
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.14.0",
		"@types/vscode": "^1.85.0",
		"@vscode/test-electron": "^2.4.0",
		"eslint": "^8.57.0",
		"mocha": "^10.4.0",
		"typescript": "^5.4.0"
	},
	"dependencies": {
		"axios": "^0.27.2",
		"crypto-js": "^4.1.1"
	},
	"__metadata": {
		"id": "e1dc558b-88e8-4dc7-9ff3-f995909485f4",
		"publisherId": "3dcd93a7-6859-431a-967b-e175b201363f",
		"publisherDisplayName": "WLY"
	},

	"license": "SEE LICENSE IN LICENSE.txt",
	"bugs": {
		"url": "https://github.com/wly2014/TranslationToolbox/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/wly2014/TranslationToolbox"
	},
	"homepage": "https://github.com/wly2014/TranslationToolbox/blob/master/README.md"
}
